{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug RTDB_PLAYGROUND",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/RTDB_PLAYGROUND.exe",
            "args": ["--coverage"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "Build with CMake",
            "MIMode": "gdb",
            "miDebuggerPath": "gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
